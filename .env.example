# Sanity Configuration
VITE_SANITY_PROJECT_ID=qvf7tpyq
VITE_SANITY_DATASET=production

# API base (quando o front e back estão em domínios diferentes)
# Ex: https://seu-back.vercel.app
VITE_API_BASE_URL=

# Checkout Configuration
# Telefone no formato: 5511999999999
VITE_WHATSAPP_NUMBER=5511999999999

# Payment Configuration (InfinitePay Checkout)
# Seu @handle (ex: "minhaloja"). Ele aparece nas URLs do checkout.
INFINITEPAY_HANDLE=minhaloja

# Para onde o InfinitePay redireciona após o pagamento (padrão: /pagamento-concluido no mesmo domínio)
# INFINITEPAY_REDIRECT_URL=https://seu-dominio.vercel.app/pagamento-concluido

# Webhook opcional (recomendado se você quiser atualizar status de pedido)
# INFINITEPAY_WEBHOOK_URL=https://seu-dominio.vercel.app/api/infinitepay-webhook

# Endpoint opcional para consultar status: POST /api/payment-check
